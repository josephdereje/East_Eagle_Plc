# Copy to .env on cPanel (or set these in Setup Python App → Environment variables)
# cPanel user: easteag1
# App path: /home/easteag1/easteagleplc
# Replace yourdomain.com with your real domain

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-key
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

SITE_URL=https://yourdomain.com

# Email (use your cPanel email or Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=East Eagle Trading PLC <noreply@yourdomain.com>
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# Optional: MySQL (recommended for production). Leave DB_ENGINE unset to use SQLite.
# DB_ENGINE=mysql
# DB_NAME=cpanel_db_name
# DB_USER=cpanel_db_user
# DB_PASSWORD=cpanel_db_password
# DB_HOST=localhost
# DB_PORT=3306
